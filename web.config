<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PHP" path="*.php" verb="*" modules="FastCgiModule" scriptProcessor="%PHP_PATH%" resourceType="Unspecified" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="TenantLoginRoute" stopProcessing="true">
          <match url="^tenant/([^/]+)/login/?$" />
          <action type="Rewrite" url="tenant_login.php?tenant={R:1}" appendQueryString="true" />
        </rule>

        <rule name="TenantDashboardRoute" stopProcessing="true">
          <match url="^tenant/([^/]+)/dashboard/?$" />
          <action type="Rewrite" url="tenant_dashboard.php?tenant={R:1}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>

